{
  "name": "@manrp/deterministic-json",
  "version": "1.0.4",
  "description": "Deterministic canonical JSON serialization with hashing",
  "keywords": [
    "deterministic",
    "canonical-json",
    "stable-json",
    "json-stringify",
    "canonical",
    "hash",
    "deterministic-hash",
    "serialization",
    "json"
  ],
  "license": "MIT",
  "author": "Juan Manuel Romero Proa",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Dmn117/deterministic-json.git"
  },
  "homepage": "https://github.com/Dmn117/deterministic-json#readme",
  "bugs": {
    "url": "https://github.com/Dmn117/deterministic-json/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "prepare": "npm run build",
    "test": "vitest"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
